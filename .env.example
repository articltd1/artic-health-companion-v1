# ==========================================
# ARTIC Health Companion - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git (it contains secrets)

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
PORT=3000
APP_NAME="ARTIC Health Companion"

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_USER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=artic_health_companion
DB_PASSWORD=password

# Connection Pool Settings
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# ==========================================
# SESSION CONFIGURATION
# ==========================================
SESSION_SECRET=change_this_to_a_random_secret_string_in_production
SESSION_RESAVE=false
SESSION_SAVE_UNINITIALIZED=true
SESSION_MAX_AGE=86400000

# ==========================================
# SECURITY
# ==========================================
# Bcrypt salt rounds (higher = slower but more secure, 10-12 recommended)
BCRYPT_SALT_ROUNDS=10

# CORS allowed origin
CORS_ORIGIN=http://localhost:3000

# ==========================================
# EXTERNAL APIS
# ==========================================

# News API (healthnews.io, newsapi.org, or similar)
NEWS_API_KEY=your_news_api_key_here

# Hugging Face API (for AI chatbot)
HUGGINGFACE_API_TOKEN=hf_YourTokenHere
HUGGINGFACE_MODEL_ID=google/gemma-1.1-7b-it

# Priaid API (for disease prediction, symptom checker)
PRIAID_API_KEY=Jy36B_GMAIL_COM_AUT
PRIAID_SECRET_KEY=Xt95DwTm2b3B4Pxc7

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_CHATBOT=true
ENABLE_DISEASE_PREDICTION=true

# ==========================================
# PRODUCTION OVERRIDES (when NODE_ENV=production)
# ==========================================
# Uncomment and adjust for production deployment
# NODE_ENV=production
# DB_HOST=prod-db.rds.amazonaws.com
# SESSION_SECRET=generate_a_secure_random_secret_here
# CORS_ORIGIN=https://artic-health.com
