<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Doctor Profile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <nav class="navbar navbar-expand-md bg-body-tertiary p-0">
    <div class="container-fluid">
      <a class="navbar-brand" href="/doctor/dashboard"><img src="/images/logo.png" alt="logo" height="45"></a>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link active" aria-current="page" href="/doctor/dashboard">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/doctor/profile">Profile</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/doctor/login">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h2>Doctor Profile</h2>
      </div>
      <div class="card-body">
        <p><strong>Name:</strong> <%= doctor.name %></p>
        <p><strong>Email:</strong> <%= doctor.email %></p>
        <p><strong>Specialization:</strong> <%= doctor.specialization %></p>
        <p><strong>Contact Number:</strong> <%= doctor.contact_number %></p>
        <p><strong>Current year:</strong> <%= currYear %></p>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>
